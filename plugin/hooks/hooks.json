{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/ensure-deps.py\"",
            "statusMessage": "prompt-engineer: Installing dependencies..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); case \"$input\" in */.claude/*/prompt-engineer/*/skills/*/scripts/*) python \"${CLAUDE_PLUGIN_ROOT}/scripts/allow-skill-scripts.py\" <<< \"$input\" ;; esac"
          }
        ]
      }
    ]
  }
}
