{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/ensure-deps.py\"",
            "statusMessage": "prompt-engineer: Installing dependencies..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(*invoke-llm/scripts/invoke.py*)",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/allow-skill-scripts.py\""
          }
        ]
      },
      {
        "matcher": "Bash(*token-counter/scripts/count.py*)",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/allow-skill-scripts.py\""
          }
        ]
      }
    ]
  }
}
